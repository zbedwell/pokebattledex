PORT=4000
DB_USE_SSH_TUNNEL=false
LOCAL_HOST=127.0.0.1
LOCAL_PORT=5432
DATABASE_NAME=battledex
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_ADMIN_NAME=postgres
DATABASE_ADMIN_USER=postgres
DATABASE_ADMIN_PASSWORD=postgres

# Only needed when DB_USE_SSH_TUNNEL=true
SSH_HOST=your-ssh-host
SSH_PORT=22
SSH_USER=your-ssh-user
SSH_PRIVATE_KEY=C:\\Users\\your-user\\.ssh\\id_rsa
SSH_PASSPHRASE=optional-passphrase
REMOTE_HOST=127.0.0.1
REMOTE_PORT=5432
